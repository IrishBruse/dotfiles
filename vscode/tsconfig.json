{
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "ES2020",
    "lib": ["ES2022"],
    "types": ["node"],
    "checkJs": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules"]
}
