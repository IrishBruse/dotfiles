{
  "name": "dotfiles-tools",
  "version": "0.1.0",
  "description": "Dotfiles CLI tools (Jira, Confluence, PR, interpolate, and more)",
  "private": true,
  "license": "ISC",
  "type": "module",
  "bin": {
    "dotfiles": "./.bin/dotfiles.js",
    "memory": "./.bin/memory.js",
    "commit": "./.bin/commit.js",
    "confluence": "./.bin/confluence.js",
    "endpoint": "./.bin/endpoint.js",
    "interpolate": "./.bin/interpolate.js",
    "jira": "./.bin/jira.js",
    "md": "./.bin/md.js",
    "pr": "./.bin/pr.js",
    "sprint": "./.bin/sprint.js"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint -c .lib/eslint.config.js .",
    "validate": "tsc --noEmit",
    "test": "node --test '**/*.test.ts'",
    "verify": "npm run validate && npm run lint && npm run format:check"
  },
  "dependencies": {
    "turndown": "7.2.4",
    "turndown-plugin-gfm": "1.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/turndown": "5.0.6",
    "eslint": "^9.39.2",
    "prettier": "3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
