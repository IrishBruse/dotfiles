{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vscode Keybind",
      "type": "shell",
      "command": "node --watch --watch-path=custom.json gen.ts",
      "problemMatcher": [],
      "options": {
        "cwd": "vscode/keybindings/"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Run on Open",
      "type": "shell",
      "osx": { "command": "node macos/open.ts" },
      "linux": { "command": "node linux/open.ts" },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      }
    },
    {
      "label": "Dashboard",
      "type": "shell",
      "command": "npm run dev",
      "detail": "http://localhost:54321",
      "options": {
        "cwd": "${workspaceFolder}/dashboard"
      },
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": {
        "owner": "dashboard",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE|Port \\d+ is in use",
          "endsPattern": "ready in|Local:\\s+http"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
