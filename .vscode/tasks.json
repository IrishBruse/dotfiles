{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vscode Keybind",
      "type": "shell",
      "command": "fnm use 24 && node --experimental-specifier-resolution=node --watch --watch-path=custom.json gen.ts",
      "problemMatcher": [],
      "options": {
        "cwd": "vscode/keybindings/"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Run on Open",
      "type": "shell",
      "osx": { "command": "fish -c ./open-mac.fish" },
      "linux": { "command": "fish -c ./open-linux.fish" },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
