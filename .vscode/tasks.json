{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vscode Keybind",
      "type": "shell",
      "command": "node --watch --watch-path=custom.json gen.ts",
      "problemMatcher": [],
      "options": {
        "cwd": "vscode/keybindings/"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Run on Open",
      "type": "shell",
      "osx": { "command": "node open-mac.ts" },
      "linux": { "command": "node open-linux.ts" },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
