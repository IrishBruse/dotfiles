{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Vscode Keybind",
      "type": "shell",
      "command": "node --watch --watch-path=custom.json gen.ts",
      "problemMatcher": [],
      "options": {
        "cwd": "vscode/keybindings/"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Run on Open",
      "type": "shell",
      "osx": { "command": "node macos/open.ts" },
      "linux": { "command": "node linux/open.ts" },
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Dashboard",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/dashboard"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "dashboard",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in|Local:"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
