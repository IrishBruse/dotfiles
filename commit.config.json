{
  "version": 1,
  "defaults": {
    "when": "any"
  },
  "rules": [
    {
      "paths": [
        "home/.config/Code/User/**",
        "home/Library/Application Support/Code/User/**"
      ],
      "prefix": "config",
      "scope": "code"
    },
    {
      "paths": "home/.cursor/rules/**",
      "prefix": "cursor",
      "scope": "rules"
    },
    {
      "paths": "home/.agents/skills/:scope/**",
      "prefix": "skill"
    },
    {
      "paths": "home/.config/:scope/**",
      "prefix": "config"
    },
    {
      "paths": "home/:scope",
      "prefix": "home",
      "when": "all"
    },
    {
      "paths": "tools/:scope/**",
      "prefix": "tools"
    },
    {
      "paths": "vscode/:scope/**",
      "prefix": "vscode"
    },
    {
      "paths": "init.fish",
      "prefix": "fish"
    },
    {
      "paths": "**/prepare-commit-msg",
      "prefix": "config",
      "scope": "git"
    },
    {
      "paths": "commit.config.json",
      "prefix": "config",
      "scope": "commit"
    }
  ]
}
