{
  "version": 1,
  "defaults": {
    "when": "any"
  },
  "rules": [
    {
      "paths": [
        "home/.config/Code/User/**",
        "home/Library/Application Support/Code/User/**"
      ],
      "message": "config(code): {{summary}}"
    },
    {
      "paths": "home/.cursor/rules/**",
      "message": "cursor(rules): {{summary}}"
    },
    {
      "paths": "home/.agents/skills/*/**",
      "message": "skill({{name}}): {{summary}}",
      "name": { "segment": 3 }
    },
    {
      "paths": "home/.config/*/**",
      "message": "config({{name}}): {{summary}}",
      "name": { "segment": 2 }
    },
    {
      "paths": "home/*",
      "when": "all",
      "message": "home({{name}}): {{summary}}",
      "name": { "segment": 1 }
    },
    {
      "paths": "tools/*/**",
      "message": "tools({{name}}): {{summary}}",
      "name": { "segment": 1 }
    },
    {
      "paths": "vscode/*/**",
      "message": "vscode({{name}}): {{summary}}",
      "name": { "segment": 1 }
    },
    {
      "paths": "init.fish",
      "message": "fish: {{summary}}"
    },
    {
      "paths": "**/prepare-commit-msg",
      "message": "config(git): {{summary}}"
    },
    {
      "paths": "commit.config.json",
      "message": "config(commit): {{summary}}"
    }
  ]
}
