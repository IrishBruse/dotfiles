[init]
	defaultBranch = main

[user]
    name = Ethan Conneely

[core]
	hooksPath = /dev/null
    editor = code --wait
	excludesFile = ~/.gitignore

[branch]
	sort = -committerdate

[safe]
	directory = ~/git/*

[commit]
	gpgsign = true

[diff]
   renames = copies
   renamelimit = 0

[push]
	autoSetupRemote = true

[advice]
	mergeConflict = false

[credential]
	helper =
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
