[init]
	defaultBranch = main

[user]
    name = Ethan Conneely

[core]
	hooksPath = /dev/null
    editor = code --wait
	excludesFile = ~/.gitignore

[branch]
	sort = -committerdate

[safe]
	directory = ~/git/*

[gpg]
	program = /usr/bin/gpg

[commit]
	gpgsign = true

[diff]
   renames = copies
   renamelimit = 0

[push]
	autoSetupRemote = true
