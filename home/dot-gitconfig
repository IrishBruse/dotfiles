[init]
	defaultBranch = main

[user]
    name = Ethan Conneely

[core]
	hooksPath = ~/.config/git/hooks
    editor = code --wait
	excludesFile = ~/.gitignore

[branch]
	sort = -committerdate

[safe]
	directory = ~/git/*

[commit]
	gpgsign = true

[diff]
   renames = copies
   renamelimit = 0

[push]
	autoSetupRemote = true

[advice]
	mergeConflict = false

