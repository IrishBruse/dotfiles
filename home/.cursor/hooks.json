{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node ./hooks/block-acli.js",
        "failClosed": true
      }
    ],
    "preToolUse": [
      {
        "command": "node ./hooks/block-acli.js",
        "matcher": "^Shell$",
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "./hooks/style-lint.js",
        "matcher": "^(Write|StrReplace)$"
      }
    ]
  }
}
